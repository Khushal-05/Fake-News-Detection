# Fake news detection API — copy to .env and set values
# MODEL_TYPE: muril or xlm-roberta (must match the checkpoint you trained)
MODEL_TYPE=muril
# Path to the .pt checkpoint (defaults to models/checkpoints/{MODEL_TYPE}_best.pt if empty)
CHECKPOINT_PATH=
# Port for the Flask server
PORT=5000
# Max sequence length for the model (must match training)
MAX_LENGTH=512
# Request limits
MAX_CONTENT_LENGTH=1048576
MAX_TEXT_LENGTH=50000
MAX_BATCH_SIZE=20
# Optional: Flask debug (0 or 1)
FLASK_DEBUG=0
# Optional: logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
